# Laravel backend
LARAVEL_BASE_URL=http://localhost:8000

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-7

# API Keys (set only the one matching LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# MCP server — path relative to orchestrator/ root
MCP_SERVER_PATH=../mcp/server.js

# Express port
PORT=3000
